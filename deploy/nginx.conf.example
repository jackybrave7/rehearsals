# Пример для Ubuntu/Debian + nginx на VPS (TimeWeb и др.)
#
# 1. npm run build  →  dist/
# 2. pm2 start npm --name rehearsals-api -- start   (API на 127.0.0.1:3001)
# 3. Скопировать в /etc/nginx/sites-available/rehearsals, подставить server_name и root
# 4. ln -s .../sites-available/rehearsals .../sites-enabled/
# 5. nginx -t && systemctl reload nginx
# 6. certbot --nginx -d ваш-домен.ru   (HTTPS, по желанию)

server {
    listen 80;
    listen [::]:80;

    # Замените на свой домен
    server_name rehearsals.example.com;

    # Абсолютный путь к каталогу dist после npm run build
    root /var/www/rehearsals/dist;
    index index.html;

    # Сохранение состояния через PUT /api/state (до ~25 MB)
    client_max_body_size 25m;

    location /api/ {
        proxy_pass http://127.0.0.1:3001;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 120s;
    }

    location / {
        try_files $uri $uri/ /index.html;
    }

    location ~* \.(?:js|css|png|jpg|jpeg|gif|ico|svg|webp|woff2?)$ {
        expires 7d;
        add_header Cache-Control "public, immutable";
        try_files $uri =404;
    }
}
