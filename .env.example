# Порт API (Express + SQLite). По умолчанию 3001.
API_PORT=3001

# OAuth Client ID для синхронизации ссылок Google Docs
# 1. https://console.cloud.google.com/apis/library/docs.googleapis.com — включить API
# 2. Credentials → OAuth client ID → Web application
# 3. Authorized JavaScript origins: http://localhost:3003 и ваш прод-домен
# 4. Скопировать Client ID сюда и перезапустить npm run dev
VITE_GOOGLE_CLIENT_ID=

# Необязательно: базовый URL API для фронтенда (по умолчанию /api)
# VITE_API_BASE=/api

# Telegram Bot API — отправка сообщения со ссылками на названиях сцен
# 1. @BotFather → /newbot → скопировать token
# 2. Добавить бота в чат, написать любое сообщение
# 3. https://api.telegram.org/bot<TOKEN>/getUpdates → chat.id
# 4. Перезапустить npm run dev
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
