# Порт API (Express + SQLite). По умолчанию 3001.
API_PORT=3001

# OAuth Client ID (Google Docs + вход через Google)
# 1. https://console.cloud.google.com/apis/library/docs.googleapis.com — включить API
# 2. Credentials → OAuth client ID → Web application
# 3. Authorized JavaScript origins: http://localhost:3003 и ваш прод-домен (https://rehears.ru)
# 4. Скопировать Client ID сюда и перезапустить npm run dev / npm run build
VITE_GOOGLE_CLIENT_ID=

# Необязательно: базовый URL API для фронтенда (по умолчанию /api)
# VITE_API_BASE=/api

# Telegram Bot API — один бот сервиса для всех театров
# 1. @BotFather → /newbot → скопировать token
# 2. Задайте TELEGRAM_BOT_TOKEN здесь (на сервере)
# 3. В настройках каждого театра укажите Chat ID рабочей группы
# 4. Перезапустите API
TELEGRAM_BOT_TOKEN=

# Устарело: общий чат для всех. Лучше указать chat ID в настройках театра.
# TELEGRAM_CHAT_ID=

# Авто-напоминания о репетициях (серверный планировщик, личные сообщения участникам)
# REMINDER_TICK_MINUTES=5
# REMINDER_WINDOW_MINUTES=10
# REHEARSAL_UTC_OFFSET_HOURS=3
# REMINDER_MORNING_HOUR=9

# Загруженные файлы (фото, сценарии) — data/uploads/
# ADMIN_EMAILS=admin@example.com,owner@theater.ru

# Почта для восстановления пароля (SMTP)
# Пример для Yandex: SMTP_HOST=smtp.yandex.ru SMTP_PORT=465 SMTP_SECURE=1
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_SECURE=0
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=noreply@example.com
# APP_URL=https://rehears.ru
